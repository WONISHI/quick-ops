{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run QuickOps Extension (monorepo root)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/apps"
      ],
      "outFiles": [
        "${workspaceFolder}/apps/dist/**/*.js"
      ],
      "preLaunchTask": "pnpm: watch-quickops"
    }
  ]
}
