{
  "name": "quick-ops",
  "displayName": "Quick Ops: Code Utils & Anchors",
  "description": "Boost productivity with Code Anchors, SCSS structure generation, and essential navigation shortcuts.",
  "version": "0.0.51",
  "engines": {
    "vscode": "^1.73.0"
  },
  "galleryBanner": {
    "color": "#e8eaed",
    "theme": "light"
  },
  "sideEffects": false,
  "publisher": "quick-ops",
  "keywords": [
    "anchor",
    "bookmark",
    "navigation",
    "scroll",
    "scss",
    "css structure",
    "productivity",
    "tool",
    "quick-ops",
    "vue",
    "react"
  ],
  "categories": [
    "Other",
    "Snippets"
  ],
  "icon": "./icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/WONISHI/quick-ops.git"
  },
  "activationEvents": [
    "onLanguage:vue",
    "onLanguage:html",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Quick Ops",
      "properties": {
        "quick-ops.general.debug": {
          "type": "boolean",
          "default": true,
          "description": "是否开启调试模式"
        },
        "quick-ops.general.use.ElementUI": {
          "type": "boolean",
          "default": true,
          "description": "是否开启 Element UI 组件的智能提示与校验"
        },
        "quick-ops.general.use.ElementPlus": {
          "type": "boolean",
          "default": true,
          "description": "是否开启 Element Plus 组件的智能提示与校验"
        },
        "quick-ops.general.use.Vant": {
          "type": "boolean",
          "default": true,
          "description": "是否开启 Vant 组件的智能提示与校验"
        },
        "quick-ops.general.use.AntDesignVue": {
          "type": "boolean",
          "default": true,
          "description": "是否开启 Ant Design Vue 组件的智能提示与校验"
        },
        "quick-ops.git.githubToken": {
          "type": "string",
          "default": "",
          "description": "GitHub Personal Access Token,用于提升获取分支等信息的 API 频率上限 (建议填写以防 403 限制)"
        },
        "quick-ops.git.userName": {
          "type": "string",
          "default": "",
          "description": "Git 提交使用的用户名 (修改后将提示是否同步到当前本地 Git 仓库)"
        },
        "quick-ops.git.userEmail": {
          "type": "string",
          "default": "",
          "description": "Git 提交使用的邮箱 (修改后将提示是否同步到当前本地 Git 仓库)"
        },
        "quick-ops.git.defaultSkipVerify": {
          "type": "boolean",
          "default": false,
          "description": "Git 提交时默认是否跳过校验 (勾选则相当于提交时附加 --no-verify 参数，面板中盾牌按钮将默认显示为'校验关闭')"
        },
        "quick-ops.general.anchorViewMode": {
          "type": "string",
          "enum": [
            "mindmap",
            "menu"
          ],
          "enumDescriptions": [
            "在左侧拆分出一个新编辑器组显示 (Split editor to the left)",
            "在当前编辑器右侧/旁边显示 (Open beside active editor)"
          ],
          "default": "mindmap",
          "description": "锚点视图的展示模式 (思维导图或列表菜单)"
        },
        "quick-ops.general.mindMapPosition": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "enumDescriptions": [
            "以思维导图形式可视化展示 (Visual Mind Map)",
            "以快速选择列表形式展示 (Quick Pick Menu)"
          ],
          "default": "right",
          "description": "思维导图视图在编辑器中打开的位置"
        },
        "quick-ops.logger.template": {
          "type": "string",
          "default": "[icon]-[~/^/^/name]-[line]-[$0]",
          "enum": [
            "[icon]-[~/^/^/name]-[line]-[$0]",
            "🚀 [name]-[line] : [$0]",
            "[$time] [name]-[line] -> [$0]",
            "[$0]"
          ],
          "enumItemLabels": [
            "默认 (带图标、路径、文件名和行号)",
            "简洁 (仅表情符号、文件名和行号)",
            "带时间戳 (时间、文件名和行号)",
            "极简 (仅输出变量本身)"
          ],
          "description": "快捷日志输出的模板格式"
        },
        "quick-ops.logger.dateFormat": {
          "type": "string",
          "default": "YYYY-MM-DD HH:mm:ss",
          "enum": [
            "YYYY-MM-DD HH:mm:ss",
            "YYYY/MM/DD HH:mm:ss",
            "MM-DD HH:mm:ss",
            "HH:mm:ss"
          ],
          "enumItemLabels": [
            "完整日期和时间 (2024-05-20 14:30:00)",
            "斜杠分隔日期 (2024/05/20 14:30:00)",
            "短日期和时间 (05-20 14:30:00)",
            "仅显示时间 (14:30:00)"
          ],
          "description": "日志输出的时间格式"
        },
        "quick-ops.utils.uuidLength": {
          "type": "number",
          "default": 12,
          "enum": [
            8,
            12,
            16,
            21,
            32
          ],
          "enumItemLabels": [
            "8位 (短 ID)",
            "12位 (默认)",
            "16位 (中等)",
            "21位 (NanoID 标准长度)",
            "32位 (长 ID / UUID)"
          ],
          "description": "生成的 UUID 长度"
        },
        "quick-ops.git.ignoreList": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Git 幽灵隔离的文件/目录列表"
        },
        "quick-ops.shells": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "预定义的 Shell 快捷脚本列表"
        },
        "quick-ops.project.marks": {
          "type": "object",
          "default": {},
          "description": "自定义代码高亮标记的样式配置"
        },
        "quick-ops.project.alias": {
          "type": "object",
          "default": {
            "@/": "./src/"
          },
          "description": "项目路径别名映射 (用于正确解析文件跳转)"
        }
      }
    },
    "languages": [
      {
        "id": "json",
        "filenames": [
          ".quickopsrc"
        ]
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": ".quickopsrc",
        "url": "./resources/schema/.quickopsrc-schema.json"
      }
    ],
    "webviews": {
      "allowScripts": true,
      "allowLinks": true
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "quick-ops-view-container",
          "title": "Quick Ops",
          "icon": "$(server)"
        }
      ]
    },
    "views": {
      "quick-ops-view-container": [
        {
          "id": "quick-ops.mockView",
          "name": "Mock服务管理器",
          "icon": "$(server)",
          "type": "webview"
        },
        {
          "id": "quickOps.recentProjectsView",
          "name": "项目资源管理器",
          "type": "webview",
          "icon": "$(history)"
        },
        {
          "id": "quickOps.gitView",
          "name": "Git 管理器",
          "type": "webview",
          "icon": "$(source-control)"
        }
      ]
    },
    "submenus": [
      {
        "id": "quick-ops.explorerSubmenu",
        "label": "Quick Ops",
        "icon": "$(zap)"
      },
      {
        "id": "quick-ops.transformSubmenu",
        "label": "转换文本格式 (Transform Text)"
      }
    ],
    "commands": [
      {
        "command": "quickOps.addRecentProject",
        "title": "添加项目",
        "icon": "$(add)"
      },
      {
        "command": "quickOps.syncBranches",
        "title": "同步所有分支状态",
        "icon": "$(repo-sync)"
      },
      {
        "command": "quickOps.refreshRecentProjects",
        "title": "刷新历史记录",
        "icon": "$(refresh)"
      },
      {
        "command": "quickOps.openRecentProject",
        "title": "打开历史项目"
      },
      {
        "command": "quickOps.removeRecentProject",
        "title": "移除该记录",
        "icon": "$(trash)"
      },
      {
        "command": "quickOps.clearRecentProjects",
        "title": "清空历史记录",
        "icon": "$(clear-all)"
      },
      {
        "command": "quickOps.refreshProjectExplorer",
        "title": "刷新资源管理器",
        "icon": "$(refresh)"
      },
      {
        "command": "quick-ops.showPackageScripts",
        "title": "运行快捷脚本 (Scripts)",
        "category": "Quick Ops",
        "icon": {
          "light": "resources/icons/light/code.svg",
          "dark": "resources/icons/dark/code.svg"
        }
      },
      {
        "command": "quick-ops.openLivePreview",
        "title": "网页预览台 (Live Preview)",
        "category": "Quick Ops",
        "icon": {
          "light": "resources/icons/light/tv-minimal.svg",
          "dark": "resources/icons/dark/tv-minimal.svg"
        }
      },
      {
        "command": "quick-ops.anchor.showMenu",
        "title": "显示冒点 (Show Anchors)",
        "category": "Quick Ops",
        "icon": "$(bookmark)"
      },
      {
        "command": "quick-ops.revealInExplorer",
        "title": "定位当前文件 (Reveal File)",
        "category": "Quick Ops",
        "icon": {
          "light": "resources/icons/light/record.svg",
          "dark": "resources/icons/dark/record.svg"
        }
      },
      {
        "command": "quick-ops.scrollToTop",
        "title": "回到顶部 (Scroll to Top)",
        "icon": {
          "light": "resources/icons/light/scroll-top.svg",
          "dark": "resources/icons/dark/scroll-top.svg"
        }
      },
      {
        "command": "quick-ops.scrollToBottom",
        "title": "回到底部 (Scroll to Bottom)",
        "category": "Quick Ops",
        "icon": {
          "light": "resources/icons/light/scroll-bottom.svg",
          "dark": "resources/icons/dark/scroll-bottom.svg"
        }
      },
      {
        "command": "quick-ops.createConfigFile",
        "title": "打开设置面板 (Open Settings)",
        "category": "Quick Ops",
        "icon": "$(settings-gear)"
      },
      {
        "command": "quick-ops.toggleIgnore",
        "title": "添加/移除 QuickOps 忽略 (Toggle Ignore)",
        "category": "Quick Ops"
      },
      {
        "command": "quick-ops.generateStyleStructure",
        "title": "生成样式结构 (Generate SCSS)",
        "category": "Quick Ops"
      },
      {
        "command": "quick-ops.anchor.add",
        "title": "添加锚点",
        "icon": "$(bookmark)"
      },
      {
        "command": "quick-ops.anchor.showMenu",
        "title": "显示锚点菜单 (Show Anchors)",
        "icon": {
          "light": "resources/icons/light/tag.svg",
          "dark": "resources/icons/dark/tag.svg"
        }
      },
      {
        "command": "quick-ops.anchor.listByGroup",
        "title": "按分组列出锚点 (List Anchors)"
      },
      {
        "command": "quick-ops.anchor.navigate",
        "title": "跳转到锚点 (Navigate Anchor)"
      },
      {
        "command": "quick-ops.anchor.delete",
        "title": "删除锚点 (Delete Anchor)"
      },
      {
        "command": "quick-ops.addToSnippets",
        "title": "添加选中内容到代码片段 (Add to Quick Ops Snippets)"
      },
      {
        "command": "quick-ops.transformToLower",
        "title": "转为全小写 (lowercase)"
      },
      {
        "command": "quick-ops.transformToCamel",
        "title": "转为小驼峰 (camelCase)"
      },
      {
        "command": "quick-ops.transformToPascal",
        "title": "转为大驼峰 (PascalCase)"
      },
      {
        "command": "quick-ops.transformToConstant",
        "title": "转为全大写常量 (CONSTANT_CASE)"
      },
      {
        "command": "quick-ops.transformToKebab",
        "title": "转为短横线 (kebab-case)"
      },
      {
        "command": "quick-ops.openTextCompare",
        "title": "文本差异对比 (Text Diff Compare)",
        "category": "Quick Ops"
      },
      {
        "command": "quickOps.selectForCompare",
        "title": "选择以进行比较",
        "icon": "$(check)"
      },
      {
        "command": "quickOps.compareWithSelected",
        "title": "与已选项目进行比较",
        "icon": "$(diff)"
      },
      {
        "command": "quick-ops.openInNewTab",
        "title": "在新标签页打开",
        "category": "QuickOps"
      },
      {
        "command": "quick-ops.openAndSplitRight",
        "title": "向右拆分",
        "category": "QuickOps"
      }
    ],
    "keybindings": [
      {
        "command": "quick-ops.switchPreviousEditor",
        "key": "alt+b",
        "mac": "opt+b",
        "when": "editorTextFocus"
      },
      {
        "command": "quick-ops.transformText",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t",
        "when": "editorHasSelection"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "quickOps.addRecentProject",
          "when": "view == quickOps.recentProjectsView",
          "group": "navigation@1"
        },
        {
          "command": "quickOps.syncBranches",
          "when": "view == quickOps.recentProjectsView",
          "group": "navigation@2"
        },
        {
          "command": "quickOps.refreshRecentProjects",
          "when": "view == quickOps.recentProjectsView",
          "group": "navigation@3"
        },
        {
          "command": "quickOps.clearRecentProjects",
          "when": "view == quickOps.recentProjectsView",
          "group": "navigation@4"
        }
      ],
      "editor/title": [
        {
          "command": "quick-ops.showPackageScripts",
          "group": "navigation@1"
        },
        {
          "command": "quick-ops.openLivePreview",
          "group": "navigation@2",
          "when": "resourceScheme == file"
        },
        {
          "command": "quick-ops.anchor.showMenu",
          "group": "navigation@3",
          "when": "quickOps.hasAnchorsInProject && resourceScheme == file"
        },
        {
          "command": "quick-ops.revealInExplorer",
          "when": "resourceScheme == file",
          "group": "navigation@4"
        },
        {
          "command": "quick-ops.scrollToTop",
          "group": "navigation@5",
          "when": "editorTextFocus"
        },
        {
          "command": "quick-ops.scrollToBottom",
          "group": "navigation@6",
          "when": "editorTextFocus"
        }
      ],
      "explorer/context": [
        {
          "command": "quick-ops.openAndSplitRight",
          "group": "navigation",
          "when": "resourceScheme == 'file'"
        },
        {
          "command": "quick-ops.openInNewTab",
          "group": "navigation",
          "when": "resourceScheme == 'file'"
        },
        {
          "submenu": "quick-ops.explorerSubmenu",
          "group": "7_modification"
        }
      ],
      "editor/context": [
        {
          "command": "quick-ops.addToSnippets",
          "group": "1_modification@1",
          "when": "editorHasSelection"
        },
        {
          "submenu": "quick-ops.transformSubmenu",
          "group": "1_modification@2",
          "when": "editorHasSelection"
        },
        {
          "command": "quick-ops.openTextCompare",
          "group": "1_modification@3"
        }
      ],
      "quick-ops.transformSubmenu": [
        {
          "command": "quick-ops.transformToLower",
          "group": "1"
        },
        {
          "command": "quick-ops.transformToCamel",
          "group": "2"
        },
        {
          "command": "quick-ops.transformToPascal",
          "group": "3"
        },
        {
          "command": "quick-ops.transformToKebab",
          "group": "4"
        },
        {
          "command": "quick-ops.transformToConstant",
          "group": "5"
        }
      ],
      "quick-ops.explorerSubmenu": [
        {
          "command": "quick-ops.createConfigFile",
          "group": "quickOps@1"
        },
        {
          "command": "quick-ops.toggleIgnore",
          "group": "quickOps@2",
          "when": "resourceScheme == file"
        },
        {
          "command": "quick-ops.generateStyleStructure",
          "group": "quickOps@3",
          "when": "resourceLangId == vue || resourceLangId == html || resourceLangId == javascriptreact || resourceLangId == typescriptreact"
        },
        {
          "command": "quickOps.selectForCompare",
          "group": "navigation@4",
          "when": "!explorerResourceIsFolder"
        },
        {
          "command": "quickOps.compareWithSelected",
          "group": "navigation@5",
          "when": "!explorerResourceIsFolder"
        }
      ],
      "editor/lineNumber/context": [
        {
          "command": "quick-ops.anchor.add",
          "group": "1_modification"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:all",
    "compile": "webpack --mode development",
    "watch:ext": "webpack --mode development --watch",
    "watch:ui": "cd webview-ui && npm run build -- --watch",
    "watch:all": "concurrently -c \"cyan.bold,green.bold\" -n \"EXT,UI\" \"npm run watch:ext\" \"npm run watch:ui\"",
    "build:ext": "webpack --mode production --devtool hidden-source-map",
    "build:ui": "cd webview-ui && npm run build",
    "build:all": "concurrently -c \"blue.bold,yellow.bold\" -n \"EXT,UI\" \"npm run build:ext\" \"npm run build:ui\"",
    "build": "npm run build:all && vsce package --no-yarn --no-dependencies",
    "preinstall": "cd webview-ui && npm install",
    "compile-tests": "tsc -p . --outDir dist",
    "watch-tests": "tsc -p . -w --outDir dist",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "node ./dist/test/extension.test.js"
  },
  "devDependencies": {
    "@babel/parser": "^7.28.6",
    "@babel/traverse": "^7.28.6",
    "@babel/types": "^7.28.6",
    "@types/babel__core": "^7.20.5",
    "@types/babel__traverse": "^7.28.0",
    "@types/cheerio": "^1.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/glob": "^9.0.0",
    "@types/http-proxy": "^1",
    "@types/lodash-es": "^4",
    "@types/mocha": "^10.0.10",
    "@types/mockjs": "^1.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.54.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.0",
    "@vue/compiler-sfc": "^3.5.20",
    "body-parser": "^2.2.2",
    "cheerio": "^1.1.2",
    "concurrently": "^9.2.1",
    "copy-webpack-plugin": "^13.0.1",
    "cors": "^2.8.6",
    "dayjs": "^1.11.13",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "express": "^5.2.1",
    "glob": "^13.0.0",
    "http-proxy": "^1.18.1",
    "lodash-es": "^4.17.23",
    "mocha": "^11.7.5",
    "mockjs": "^1.1.0",
    "nanoid": "^5.1.6",
    "prettier": "^3.6.2",
    "pug": "^3.0.3",
    "simple-git": "^3.35.2",
    "terser-webpack-plugin": "^5.3.14",
    "ts-loader": "^9.5.2",
    "typescript": "^5.9.2",
    "webpack": "^5.101.0",
    "webpack-bundle-analyzer": "^5.2.0",
    "webpack-cli": "^6.0.1",
    "ws": "^8.20.0"
  },
  "volta": {
    "node": "22.18.0",
    "yarn": "4.10.3"
  }
}
