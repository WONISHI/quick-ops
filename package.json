{
  "name": "quick-ops",
  "displayName": "Quick Ops: Code Utils & Anchors",
  "description": "Boost productivity with Code Anchors, SCSS structure generation, and essential navigation shortcuts.",
  "version": "0.0.36",
  "engines": {
    "vscode": "^1.73.0"
  },
  "galleryBanner": {
    "color": "#e8eaed",
    "theme": "light"
  },
  "sideEffects": false,
  "publisher": "quick-ops",
  "keywords": [
    "anchor",
    "bookmark",
    "navigation",
    "scroll",
    "scss",
    "css structure",
    "productivity",
    "tool",
    "quick-ops",
    "vue",
    "react"
  ],
  "categories": [
    "Other",
    "Snippets"
  ],
  "icon": "./icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/WONISHI/quick-ops.git"
  },
  "activationEvents": [
    "onLanguage"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Quick Ops",
      "properties": {
        "quick-ops.general.debug": {
          "type": "boolean",
          "default": true,
          "description": "是否开启调试模式"
        },
        "quick-ops.general.use.ElementUI": {
          "type": "boolean",
          "default": true,
          "description": "是否开启 Element UI 组件的智能提示与校验"
        },
        "quick-ops.general.use.ElementPlus": {
          "type": "boolean",
          "default": true,
          "description": "是否开启 Element Plus 组件的智能提示与校验"
        },
        "quick-ops.general.use.Vant": {
          "type": "boolean",
          "default": true,
          "description": "是否开启 Vant 组件的智能提示与校验"
        },
        "quick-ops.general.use.AntDesignVue": {
          "type": "boolean",
          "default": true,
          "description": "是否开启 Ant Design Vue 组件的智能提示与校验"
        },
        "quick-ops.general.anchorViewMode": {
          "type": "string",
          "enum": [
            "mindmap",
            "menu"
          ],
          "enumDescriptions": [
            "在左侧拆分出一个新编辑器组显示 (Split editor to the left)",
            "在当前编辑器右侧/旁边显示 (Open beside active editor)"
          ],
          "default": "mindmap",
          "description": "锚点视图的展示模式 (思维导图或列表菜单)"
        },
        "quick-ops.general.mindMapPosition": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "enumDescriptions": [
            "以思维导图形式可视化展示 (Visual Mind Map)",
            "以快速选择列表形式展示 (Quick Pick Menu)"
          ],
          "default": "right",
          "description": "思维导图视图在编辑器中打开的位置"
        },
        "quick-ops.logger.template": {
          "type": "string",
          "default": "[icon]-[~/^/^/name]-[line]-[$0]",
          "enum": [
            "[icon]-[~/^/^/name]-[line]-[$0]",
            "🚀 [name]-[line] : [$0]",
            "[$time] [name]-[line] -> [$0]",
            "[$0]"
          ],
          "enumItemLabels": [
            "默认 (带图标、路径、文件名和行号)",
            "简洁 (仅表情符号、文件名和行号)",
            "带时间戳 (时间、文件名和行号)",
            "极简 (仅输出变量本身)"
          ],
          "description": "快捷日志输出的模板格式"
        },
        "quick-ops.logger.dateFormat": {
          "type": "string",
          "default": "YYYY-MM-DD HH:mm:ss",
          "enum": [
            "YYYY-MM-DD HH:mm:ss",
            "YYYY/MM/DD HH:mm:ss",
            "MM-DD HH:mm:ss",
            "HH:mm:ss"
          ],
          "enumItemLabels": [
            "完整日期和时间 (2024-05-20 14:30:00)",
            "斜杠分隔日期 (2024/05/20 14:30:00)",
            "短日期和时间 (05-20 14:30:00)",
            "仅显示时间 (14:30:00)"
          ],
          "description": "日志输出的时间格式"
        },
        "quick-ops.utils.uuidLength": {
          "type": "number",
          "default": 12,
          "enum": [
            8,
            12,
            16,
            21,
            32
          ],
          "enumItemLabels": [
            "8位 (短 ID)",
            "12位 (默认)",
            "16位 (中等)",
            "21位 (NanoID 标准长度)",
            "32位 (长 ID / UUID)"
          ],
          "description": "生成的 UUID 长度"
        },
        "quick-ops.git.ignoreList": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Git 幽灵隔离的文件/目录列表"
        },
        "quick-ops.shells": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "预定义的 Shell 快捷脚本列表"
        },
        "quick-ops.project.marks": {
          "type": "object",
          "default": {
            "@FIXME": {
              "backgroundColor": "#9c27b0",
              "color": "#fff",
              "borderRadius": "2px"
            },
            "@OPTIMIZE": {
              "backgroundColor": "#00bcd4",
              "color": "#fff"
            }
          },
          "description": "自定义代码高亮标记的样式配置"
        },
        "quick-ops.project.alias": {
          "type": "object",
          "default": {
            "@/": "./src/"
          },
          "description": "项目路径别名映射 (用于正确解析文件跳转)"
        }
      }
    },
    "languages": [
      {
        "id": "json",
        "filenames": [
          ".quickopsrc"
        ]
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": ".quickopsrc",
        "url": "./resources/schema/.quickopsrc-schema.json"
      }
    ],
    "webviews": {
      "allowScripts": true,
      "allowLinks": true
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "quick-ops-view-container",
          "title": "Quick Ops",
          "icon": "$(server)"
        }
      ]
    },
    "views": {
      "quick-ops-view-container": [
        {
          "id": "quick-ops.mockView",
          "name": "Mock服务管理器",
          "icon": "$(server)",
          "type": "webview"
        },
        {
          "id": "quickOps.recentProjectsView",
          "name": "项目资源管理器",
          "type": "webview",
          "icon": "$(history)"
        }
      ]
    },
    "submenus": [
      {
        "id": "quick-ops.explorerSubmenu",
        "label": "Quick Ops",
        "icon": "$(zap)"
      }
    ],
    "commands": [
      {
        "command": "quickOps.addRecentProject",
        "title": "添加项目",
        "icon": "$(add)"
      },
      {
        "command": "quickOps.refreshRecentProjects",
        "title": "刷新历史记录",
        "icon": "$(refresh)"
      },
      {
        "command": "quickOps.openRecentProject",
        "title": "打开历史项目"
      },
      {
        "command": "quickOps.removeRecentProject",
        "title": "移除该记录",
        "icon": "$(trash)"
      },
      {
        "command": "quickOps.clearRecentProjects",
        "title": "清空历史记录",
        "icon": "$(clear-all)"
      },
      {
        "command": "quickOps.refreshProjectExplorer",
        "title": "刷新资源管理器",
        "icon": "$(refresh)"
      },
      {
        "command": "quick-ops.showPackageScripts",
        "title": "运行快捷脚本 (Scripts)",
        "category": "Quick Ops",
        "icon": "$(terminal-powershell)"
      },
      {
        "command": "quick-ops.openLivePreview",
        "title": "网页预览台 (Live Preview)",
        "category": "Quick Ops",
        "icon": "$(vm-small)"
      },
      {
        "command": "quick-ops.anchor.showMenu",
        "title": "显示冒点 (Show Anchors)",
        "category": "Quick Ops",
        "icon": "$(bookmark)"
      },
      {
        "command": "quick-ops.revealInExplorer",
        "title": "定位当前文件 (Reveal File)",
        "category": "Quick Ops",
        "icon": "$(record)"
      },
      {
        "command": "quick-ops.scrollToTop",
        "title": "回到顶部 (Scroll to Top)",
        "icon": "$(fold-up)"
      },
      {
        "command": "quick-ops.scrollToBottom",
        "title": "回到底部 (Scroll to Bottom)",
        "category": "Quick Ops",
        "icon": "$(fold-down)"
      },
      {
        "command": "quick-ops.createConfigFile",
        "title": "打开设置面板 (Open Settings)",
        "category": "Quick Ops",
        "icon": "$(settings-gear)"
      },
      {
        "command": "quick-ops.toggleIgnore",
        "title": "添加/移除 QuickOps 忽略 (Toggle Ignore)",
        "category": "Quick Ops"
      },
      {
        "command": "quick-ops.generateStyleStructure",
        "title": "生成样式结构 (Generate SCSS)",
        "category": "Quick Ops"
      },
      {
        "command": "quick-ops.anchor.add",
        "title": "添加锚点",
        "icon": "$(bookmark)"
      },
      {
        "command": "quick-ops.anchor.showMenu",
        "title": "显示锚点菜单 (Show Anchors)",
        "icon": "$(bookmark)"
      },
      {
        "command": "quick-ops.anchor.listByGroup",
        "title": "List Anchors"
      },
      {
        "command": "quick-ops.anchor.navigate",
        "title": "Navigate Anchor"
      },
      {
        "command": "quick-ops.anchor.delete",
        "title": "Delete Anchor"
      },
      {
        "command": "quick-ops.addToSnippets",
        "title": "添加选中内容到代码片段 (Add to Quick Ops Snippets)"
      },
      {
        "command": "quick-ops.transformToLower",
        "title": "转换选中内容为全部小写 (Selection to lowercase)"
      },
      {
        "command": "quick-ops.transformToCamel",
        "title": "转换选中内容为小驼峰 (Selection to camelCase)"
      },
      {
        "command": "quick-ops.transformToPascal",
        "title": "转换选中内容为大驼峰 (Selection to PascalCase)"
      },
      {
        "command": "quick-ops.transformToConstant",
        "title": "转换选中内容为全大写常量 (Selection to CONSTANT_CASE)"
      },
      {
        "command": "quick-ops.transformToFirstUpper",
        "title": "转换选中内容为首字母大写 (Selection to UpperFirst)"
      },
      {
        "command": "quick-ops.transformToKebab",
        "title": "转换选中内容为短横线 (Selection to kebab-case)"
      },
      {
        "command": "quick-ops.switchPreviousEditor",
        "title": "Quick Ops: Switch to Previous Editor",
        "category": "Quick Ops"
      },
      {
        "command": "quickOps.showTerminal",
        "title": "显示终端",
        "icon": "$(diff-modified)"
      },
      {
        "command": "quickOps.hideTerminal",
        "title": "隐藏终端",
        "icon": "$(diff-ignored)"
      }
    ],
    "keybindings": [
      {
        "command": "quick-ops.switchPreviousEditor",
        "key": "alt+b",
        "mac": "opt+b",
        "when": "editorTextFocus"
      },
      {
        "command": "quick-ops.transformToKebab",
        "key": "ctrl+alt+k",
        "mac": "cmd+alt+k",
        "when": "editorTextFocus"
      },
      {
        "command": "quick-ops.transformToLower",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l",
        "when": "editorTextFocus"
      },
      {
        "command": "quick-ops.transformToCamel",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "editorTextFocus"
      },
      {
        "command": "quick-ops.transformToPascal",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p",
        "when": "editorTextFocus"
      },
      {
        "command": "quick-ops.transformToConstant",
        "key": "ctrl+alt+u",
        "mac": "cmd+alt+u",
        "when": "editorTextFocus"
      },
      {
        "command": "quick-ops.transformToFirstUpper",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "quickOps.addRecentProject",
          "when": "view == quickOps.recentProjectsView",
          "group": "navigation@1"
        },
        {
          "command": "quickOps.refreshRecentProjects",
          "when": "view == quickOps.recentProjectsView",
          "group": "navigation@2"
        },
        {
          "command": "quickOps.clearRecentProjects",
          "when": "view == quickOps.recentProjectsView",
          "group": "navigation@3"
        }
      ],
      "editor/title": [
        {
          "command": "quick-ops.showPackageScripts",
          "group": "navigation@1"
        },
        {
          "command": "quickOps.showTerminal",
          "when": "!quickOps.terminalVisible",
          "group": "navigation@2"
        },
        {
          "command": "quickOps.hideTerminal",
          "when": "quickOps.terminalVisible",
          "group": "navigation@3"
        },
        {
          "command": "quick-ops.openLivePreview",
          "group": "navigation@4",
          "when": "resourceScheme == file"
        },
        {
          "command": "quick-ops.anchor.showMenu",
          "group": "navigation@5",
          "when": "quickOps.hasAnchorsInCurrentFile"
        },
        {
          "command": "quick-ops.revealInExplorer",
          "when": "resourceScheme == file",
          "group": "navigation@6"
        },
        {
          "command": "quick-ops.scrollToTop",
          "group": "navigation@7",
          "when": "editorTextFocus"
        },
        {
          "command": "quick-ops.scrollToBottom",
          "group": "navigation@8",
          "when": "editorTextFocus"
        }
      ],
      "explorer/context": [
        {
          "submenu": "quick-ops.explorerSubmenu",
          "group": "7_modification"
        }
      ],
      "editor/context": [
        {
          "submenu": "quick-ops.explorerSubmenu",
          "group": "7_modification"
        },
        {
          "command": "quick-ops.addToSnippets",
          "group": "1_modification",
          "when": "editorHasSelection"
        }
      ],
      "quick-ops.explorerSubmenu": [
        {
          "command": "quick-ops.createConfigFile",
          "group": "quickOps@1"
        },
        {
          "command": "quick-ops.toggleIgnore",
          "group": "quickOps@5",
          "when": "resourceScheme == file"
        },
        {
          "command": "quick-ops.generateStyleStructure",
          "group": "quickOps@2",
          "when": "resourceLangId == vue || resourceLangId == html || resourceLangId == javascriptreact || resourceLangId == typescriptreact"
        }
      ],
      "editor/lineNumber/context": [
        {
          "command": "quick-ops.anchor.add",
          "group": "1_modification"
        }
      ]
    }
  },
  "scripts": {
    "build": "npx vsce package --no-yarn --no-dependencies",
    "vscode:prepublish": "pnpm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir dist",
    "watch-tests": "tsc -p . -w --outDir dist",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "node ./dist/test/extension.test.js"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/babel__traverse": "^7.28.0",
    "@types/cheerio": "^1.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/glob": "^9.0.0",
    "@types/lodash-es": "^4",
    "@types/mocha": "^10.0.10",
    "@types/mockjs": "^1.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.54.0",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.0",
    "copy-webpack-plugin": "^13.0.1",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "glob": "^13.0.0",
    "mocha": "^11.7.5",
    "prettier": "^3.6.2",
    "pug": "^3.0.3",
    "ts-loader": "^9.5.2",
    "typescript": "^5.9.2",
    "webpack": "^5.101.0",
    "webpack-bundle-analyzer": "^5.2.0",
    "webpack-cli": "^6.0.1"
  },
  "volta": {
    "node": "22.18.0",
    "yarn": "4.10.3"
  },
  "dependencies": {
    "@babel/parser": "^7.28.6",
    "@babel/traverse": "^7.28.6",
    "@babel/types": "^7.28.6",
    "@vue/compiler-sfc": "^3.5.20",
    "body-parser": "^2.2.2",
    "cheerio": "^1.1.2",
    "cors": "^2.8.6",
    "dayjs": "^1.11.13",
    "express": "^5.2.1",
    "lodash-es": "^4.17.23",
    "mockjs": "^1.1.0",
    "nanoid": "^5.1.6",
    "terser-webpack-plugin": "^5.3.14"
  }
}