{
  "general": {
    "debug": true,
    "excludeConfigFiles": false,
    "anchorViewMode": "mindmap",
    "mindMapPosition": "right",
    "excludeTelemetryFile": true
  },
  "logger": {
    "template": "[icon]-[~/^/^/name]-[line]-[$0]",
    "dateFormat": "YYYY-MM-DD HH:mm:ss"
  },
  "utils": {
    "uuidLength": 12
  },
  "git": {
    "ignoreList": []
  },
  "shells": [],
  "project": {
    "alias": {
      "@/": "./src/"
    }
  }
}